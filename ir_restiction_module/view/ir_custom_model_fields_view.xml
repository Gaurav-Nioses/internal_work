<odoo>
  <data>
    <record id="view_ir_model_fields_form_inherit_restrict" model="ir.ui.view">
      <field name="name">ir.model.fields.form.inherit.restrict</field>
      <field name="model">ir.model.fields</field>
      <field name="inherit_id" ref="base.view_model_fields_form"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='copied']" position="after">
          <field name="is_restricted" groups="base.group_system"/>
        </xpath>
      </field>
    </record>
  </data>
</odoo>
